{% extends '@frontend/frontend.html.twig' %}

{% block title %}{{ 'ext.demo-module.demo.frontend.title'|trans }}{% endblock %}

{% block frontend_body %}
    {% set demo_base = extension_setting('demo-module', 'demo.route', 'demo')|default('demo')|trim('/') %}
    {% set demo_base = demo_base == '' ? 'demo' : demo_base %}
    {% set display_mode = extension_setting('demo-module', 'display.mode', 'expanded')|default('expanded') %}
    {% set display_mode = display_mode in ['compact', 'expanded'] ? display_mode : 'expanded' %}

    <section class="system-frontend-content-page demo-module-frontend-demo demo-module-frontend-demo-{{ display_mode }}">
        {% include '@frontend/partials/typography/_page-header.html.twig' with {
            kicker: 'ext.demo-module.demo.kicker'|trans,
            title: 'ext.demo-module.demo.frontend.title'|trans,
            subtitle: 'ext.demo-module.demo.frontend.subtitle'|trans,
        } only %}

        {% include '@frontend/partials/actions/_button-group.html.twig' with {
            actions: [
                {label: 'ext.demo-module.navigation.backend'|trans, href: path('content_show', {path: demo_base ~ '/backend'}), variant: 'primary'},
                {label: 'ext.demo-module.navigation.typography'|trans, href: path('content_show', {path: demo_base ~ '/typography'}), variant: 'secondary'},
            ],
        } only %}

        <section class="demo-module-frontend-contract" aria-labelledby="demo-module-contract-title">
            <header>
                <div>
                    <p class="system-kicker">{{ 'ext.demo-module.demo.contract.kicker'|trans }}</p>
                    <h2 id="demo-module-contract-title">{{ 'ext.demo-module.demo.contract.title'|trans }}</h2>
                </div>
                <span class="system-badge system-badge-info">{{ ('ext.demo-module.settings.display_mode.options.' ~ display_mode)|trans }}</span>
            </header>

            <p class="system-muted">{{ 'ext.demo-module.demo.contract.text'|trans({'%route%': '/' ~ demo_base}) }}</p>

            <div class="demo-module-contract-grid">
                {% for item in [
                    {title: 'ext.demo-module.demo.contract.items.routes.title', text: 'ext.demo-module.demo.contract.items.routes.text', badge: 'module'},
                    {title: 'ext.demo-module.demo.contract.items.dynamic.title', text: 'ext.demo-module.demo.contract.items.dynamic.text', badge: 'slot'},
                    {title: 'ext.demo-module.demo.contract.items.settings.title', text: 'ext.demo-module.demo.contract.items.settings.text', badge: 'settings'},
                    {title: 'ext.demo-module.demo.contract.items.assets.title', text: 'ext.demo-module.demo.contract.items.assets.text', badge: 'assets'}
                ] %}
                    <article class="demo-module-contract-card">
                        <span class="system-badge system-badge-neutral">{{ item.badge }}</span>
                        <h3>{{ item.title|trans }}</h3>
                        {% if display_mode == 'expanded' %}
                            <p>{{ item.text|trans }}</p>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>
        </section>

        <div class="demo-module-grid">
            <section class="system-panel">
                <h2>{{ 'ext.demo-module.demo.frontend.content_title'|trans }}</h2>
                <p class="system-muted">{{ 'ext.demo-module.demo.frontend.content_text'|trans }}</p>
                <div class="system-rich-text">
                    <p>{{ 'ext.demo-module.demo.frontend.rich_text'|trans }}</p>
                </div>
            </section>

            {% include '@frontend/partials/feedback/_empty-state.html.twig' with {
                title: 'ext.demo-module.demo.empty.title'|trans,
                message: 'ext.demo-module.demo.empty.message'|trans,
            } only %}
        </div>

        <section class="system-panel">
            <header class="system-page-header">
                <div>
                    <p class="system-kicker">{{ 'ext.demo-module.demo.form.kicker'|trans }}</p>
                    <h2>{{ 'ext.demo-module.demo.form.title'|trans }}</h2>
                </div>
                <span class="system-badge system-badge-info">{{ 'ext.demo-module.demo.badges.info'|trans }}</span>
            </header>

            <div class="demo-module-grid">
                {% include '@frontend/partials/forms/_field.html.twig' with {
                    id: 'demo_frontend_title',
                    label: 'ext.demo-module.demo.form.title_label'|trans,
                    required: true,
                    help: 'ext.demo-module.demo.form.help'|trans,
                    control: '<input id="demo_frontend_title" class="system-control" value="' ~ ('ext.demo-module.demo.form.value'|trans|e('html_attr')) ~ '">',
                } only %}
                {% include '@frontend/partials/forms/_field.html.twig' with {
                    id: 'demo_frontend_status',
                    label: 'ext.demo-module.demo.form.status_label'|trans,
                    control: '<select id="demo_frontend_status" class="system-control"><option>' ~ ('ext.demo-module.demo.form.status_option'|trans|e) ~ '</option></select>',
                } only %}
            </div>
        </section>

        <section class="system-panel">
            <h2>{{ 'ext.demo-module.demo.status.title'|trans }}</h2>
            <div class="system-page-actions">
                <span class="system-badge system-badge-success">{{ 'ext.demo-module.demo.badges.success'|trans }}</span>
                <span class="system-badge system-badge-info">{{ 'ext.demo-module.demo.badges.info'|trans }}</span>
                <span class="system-badge system-badge-warning">{{ 'ext.demo-module.demo.badges.warning'|trans }}</span>
                <span class="system-badge system-badge-error">{{ 'ext.demo-module.demo.badges.error'|trans }}</span>
            </div>
        </section>
    </section>
{% endblock %}
